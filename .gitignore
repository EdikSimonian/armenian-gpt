# Data directory — all artifacts (raw text, tokenized bins, tokenizer JSON,
# SFT sources, etc.) live here and are regenerable. Everything inside is
# ignored; keep the directory itself via a .gitkeep if needed.
data/*
!data/.gitkeep
data_chat/

# Pipeline logs
pipeline_log.txt
train.log
watchdog.log
stop_monitor.log
finetune*.log

# HF Space clone (separate git repo, serves fine-tuned model)
core/hf-space/

# Checkpoints
checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

